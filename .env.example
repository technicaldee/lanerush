NEXT_PUBLIC_CELO_RPC_URLS=

# Server RPCs (leaderboard indexing, payout tx)
CELO_SEPOLIA_RPC_URL=
CELO_RPC_URL=
CELO_RPC_URLS=

# cUSD token + platform treasury + deployed game
NEXT_PUBLIC_CUSD_TOKEN_ADDRESS=
NEXT_PUBLIC_PLATFORM_WALLET_ADDRESS=
NEXT_PUBLIC_GAME_CONTRACT_ADDRESS=

# WalletConnect (optional QR fallback)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Deployer / owner key (payout + deploy only — never expose to client)
DEPLOYER_PRIVATE_KEY=
